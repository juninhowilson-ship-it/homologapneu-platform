generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Manufacturer {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  vehicles Vehicle[]

  @@map("manufacturers")
}

model TireManufacturer {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  country   String
  website   String?
  notes     String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tires     Tire[]

  @@map("tire_manufacturers")
}

enum FuelType {
  FLEX
  GASOLINA
  DIESEL
  ELETRICO
  HIBRIDO
}

enum VehicleCategory {
  HATCH
  SEDAN
  SUV
  PICAPE
  PERUA
  MINIVAN
  COUPE
}

enum VehicleSegment {
  POPULAR
  MEDIO
  PREMIUM
  LUXO
}

model Vehicle {
  id             Int              @id @default(autoincrement())
  manufacturerId Int
  model          String
  version        String
  yearStart      Int
  yearEnd        Int
  engine         String
  power          String?
  fuel           FuelType
  category       VehicleCategory
  segment        VehicleSegment?
  country        String?
  imageUrl       String?
  notes          String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  manufacturer   Manufacturer     @relation(fields: [manufacturerId], references: [id])
  homologations  Homologation[]

  @@unique([manufacturerId, model, version, engine])
  @@map("vehicles")
}

enum TireCategory {
  PASSEIO
  SUV
  CAMINHONETE
  ESPORTIVO
  INVERNO
  COMERCIAL
}

enum TireSegment {
  POPULAR
  MEDIO
  PREMIUM
  LUXO
}

model Tire {
  id                 Int              @id @default(autoincrement())
  tireManufacturerId Int
  brand              String
  model              String
  size               String
  width              Int
  profile            Int
  rim                Int
  loadIndex          String
  speedIndex         String
  runFlat            Boolean          @default(false)
  xl                 Boolean          @default(false)
  seal               Boolean          @default(false)
  tubeless           Boolean          @default(true)
  category           TireCategory
  segment            TireSegment?
  ean                String?          @unique
  description        String?
  imageUrl           String?
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  tireManufacturer   TireManufacturer   @relation(fields: [tireManufacturerId], references: [id])
  homologationTires  HomologationTire[]

  @@unique([tireManufacturerId, model, size])
  @@map("tires")
}

enum HomologationTireRole {
  ORIGINAL
  OPCIONAL
}

model Homologation {
  id        Int      @id @default(autoincrement())
  code      String
  vehicleId Int
  year      Int
  version   String
  engine    String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle            @relation(fields: [vehicleId], references: [id])
  tires   HomologationTire[]

  @@unique([vehicleId, code])
  @@map("homologations")
}

model HomologationTire {
  id             Int                  @id @default(autoincrement())
  homologationId Int
  tireId         Int
  role           HomologationTireRole @default(ORIGINAL)
  createdAt      DateTime             @default(now())

  homologation Homologation @relation(fields: [homologationId], references: [id], onDelete: Cascade)
  tire         Tire         @relation(fields: [tireId], references: [id])

  @@unique([homologationId, tireId])
  @@map("homologation_tires")
}

model SearchLog {
  id           Int      @id @default(autoincrement())
  resumo       String
  veiculoBusca String?
  pneuBusca    String?
  resultCount  Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@map("search_logs")
}
