generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Manufacturer {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  vehicles Vehicle[]

  @@map("manufacturers")
}

model TireManufacturer {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  country   String
  website   String?
  notes     String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tires     Tire[]

  @@map("tire_manufacturers")
}

enum FuelType {
  FLEX
  GASOLINA
  DIESEL
  ELETRICO
  HIBRIDO
}

enum VehicleCategory {
  HATCH
  SEDAN
  SUV
  PICAPE
  PERUA
  MINIVAN
  COUPE
}

enum VehicleSegment {
  POPULAR
  MEDIO
  PREMIUM
  LUXO
}

model Vehicle {
  id             Int              @id @default(autoincrement())
  manufacturerId Int
  model          String
  version        String
  yearStart      Int
  yearEnd        Int
  engine         String
  power          String?
  fuel           FuelType
  category       VehicleCategory
  segment        VehicleSegment?
  country        String?
  imageUrl       String?
  notes          String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  manufacturer   Manufacturer     @relation(fields: [manufacturerId], references: [id])
  homologations  Homologation[]

  @@unique([manufacturerId, model, version, engine])
  @@map("vehicles")
}

model Tire {
  id                 Int              @id @default(autoincrement())
  tireManufacturerId Int
  model              String
  size               String
  loadIndex          String
  speedIndex         String
  runFlat            Boolean          @default(false)
  xl                 Boolean          @default(false)
  tireManufacturer   TireManufacturer @relation(fields: [tireManufacturerId], references: [id])
  homologations      Homologation[]

  @@map("tires")
}

model Homologation {
  id        Int     @id @default(autoincrement())
  code      String
  vehicleId Int
  tireId    Int
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  tire      Tire    @relation(fields: [tireId], references: [id])

  @@map("homologations")
}
