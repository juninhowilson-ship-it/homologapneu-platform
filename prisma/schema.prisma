generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ValidationStatus {
  VALIDADO
  NECESSITA_VALIDACAO
  REJEITADO
}

enum FuelType {
  FLEX
  GASOLINA
  DIESEL
  ELETRICO
  HIBRIDO
}

enum VehicleCategory {
  HATCH
  SEDAN
  SUV
  PICAPE
  PERUA
  MINIVAN
  COUPE
}

enum VehicleSegment {
  POPULAR
  MEDIO
  PREMIUM
  LUXO
}

enum TransmissionType {
  MANUAL
  AUTOMATICA
  CVT
  AUTOMATIZADA
  DUPLA_EMBREAGEM
}

enum VehicleImageType {
  PRINCIPAL
  FRONTAL
  TRASEIRA
  LATERAL
}

enum DrivetrainType {
  DIANTEIRA
  TRASEIRA
  INTEGRAL
}

model Manufacturer {
  id                Int              @id @default(autoincrement())
  /// Marca comercial (ex.: "Chevrolet"). Nome principal, usado em toda a
  /// aplicacao (busca, homologacoes, etc.).
  name              String           @unique
  /// Montadora/razao social da entidade fabricante, quando distinta da
  /// marca comercial (ex.: "General Motors do Brasil Ltda."). Null quando
  /// marca e montadora coincidem ou ainda nao foi confirmada.
  legalName         String?
  automotiveGroupId Int?
  country           String?
  logoUrl           String?
  website           String?
  notes             String?
  isActive          Boolean          @default(true)
  /// Data de inicio da comercializacao oficial no Brasil.
  marketStartDate   DateTime?
  /// Data de encerramento da comercializacao no Brasil (null = ainda ativa
  /// ou desconhecida).
  marketEndDate     DateTime?
  validationStatus  ValidationStatus @default(NECESSITA_VALIDACAO)
  source            String?
  /// Nivel de confianca (0-100) da fonte que originou/atualizou este
  /// registro pela ultima vez. Null quando nao informado pela fonte.
  confidence        Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  automotiveGroup   AutomotiveGroup? @relation(fields: [automotiveGroupId], references: [id])
  models            VehicleModel[]

  @@index([automotiveGroupId])
  @@map("manufacturers")
}

/// Grupo automotivo/holding que controla uma ou mais montadoras/marcas
/// (ex.: "Stellantis", "Volkswagen Group"). Tabela de referencia, vazia ate
/// ser populada via find-or-create pelo pipeline de importacao.
model AutomotiveGroup {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  manufacturers Manufacturer[]

  @@map("automotive_groups")
}

model VehicleModel {
  id             Int      @id @default(autoincrement())
  manufacturerId Int
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  manufacturer   Manufacturer        @relation(fields: [manufacturerId], references: [id])
  generations    VehicleGeneration[]
  versions       VehicleVersion[]

  @@unique([manufacturerId, name])
  @@index([manufacturerId])
  @@map("vehicle_models")
}

model VehicleGeneration {
  id             Int      @id @default(autoincrement())
  vehicleModelId Int
  name           String
  yearStart      Int
  yearEnd        Int?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehicleModel   VehicleModel     @relation(fields: [vehicleModelId], references: [id])
  versions       VehicleVersion[]

  @@unique([vehicleModelId, name])
  @@index([vehicleModelId])
  @@map("vehicle_generations")
}

model Engine {
  id        Int      @id @default(autoincrement())
  name      String
  fuel      FuelType
  power     String?
  /// Torque maximo (texto livre, ex.: "20,4 kgfm" ou "200 Nm") — formatos
  /// variam por fabricante/fonte, por isso mantido como texto como `power`.
  torque    String?
  turbo     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions  VehicleVersion[]

  @@unique([name, fuel, power])
  @@map("engines")
}

/// Plataforma/arquitetura veicular (ex.: "MQB", "GM Gamma II"),
/// compartilhada por varias versoes/modelos. Tabela de referencia, vazia
/// ate ser populada via find-or-create pelo pipeline de importacao.
model Platform {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  versions    VehicleVersion[]

  @@map("platforms")
}

model Transmission {
  id          Int              @id @default(autoincrement())
  type        TransmissionType
  gears       Int?
  description String?
  createdAt   DateTime         @default(now())

  versions    VehicleVersion[]

  @@unique([type, gears, description])
  @@map("transmissions")
}

model VehicleVersion {
  id                   Int              @id @default(autoincrement())
  vehicleModelId       Int
  generationId         Int?
  engineId             Int
  transmissionId       Int?
  platformId           Int?
  name                 String
  /// Codigo interno do fabricante/fonte para esta versao (ex.: codigo de
  /// catalogo, codigo FIPE), quando existir.
  internalCode         String?
  yearStart            Int
  yearEnd              Int
  /// Ano de fabricacao (faixa), distinto do ano modelo (yearStart/yearEnd)
  /// quando a fonte informar essa diferenca. Null ate ser confirmado.
  manufactureYearStart Int?
  manufactureYearEnd   Int?
  category             VehicleCategory
  /// Categoria oficial de uso/classificacao do veiculo conforme orgao de
  /// transito (ex.: "Automovel", "Camioneta", "Utilitario") — distinta de
  /// `category` (carroceria). Texto livre ate normalizarmos com uma fonte
  /// oficial confirmada.
  regulatoryCategory   String?
  segment              VehicleSegment?
  drivetrain           DrivetrainType?
  doors                Int?
  country              String?
  notes                String?
  isActive             Boolean          @default(true)
  validationStatus     ValidationStatus @default(NECESSITA_VALIDACAO)
  source               String?
  validatedBy          String?
  validatedAt          DateTime?
  confidence           Int?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  vehicleModel     VehicleModel       @relation(fields: [vehicleModelId], references: [id])
  generation       VehicleGeneration? @relation(fields: [generationId], references: [id])
  engine           Engine             @relation(fields: [engineId], references: [id])
  transmission     Transmission?      @relation(fields: [transmissionId], references: [id])
  platform         Platform?          @relation(fields: [platformId], references: [id])
  images           VehicleImage[]
  documents        VehicleDocument[]
  homologations    Homologation[]

  @@unique([vehicleModelId, name, engineId])
  @@index([vehicleModelId])
  @@index([category])
  @@index([yearStart, yearEnd])
  @@index([validationStatus])
  @@index([platformId])
  @@map("vehicle_versions")
}

/// Documentos oficiais do veiculo (manual do proprietario, catalogo/ficha
/// tecnica), complementares as fotos em VehicleImage. type distingue o
/// tipo de documento (ex.: "MANUAL", "CATALOGO").
model VehicleDocument {
  id               Int      @id @default(autoincrement())
  vehicleVersionId Int
  name             String
  url              String
  type             String?
  createdAt        DateTime @default(now())

  vehicleVersion   VehicleVersion @relation(fields: [vehicleVersionId], references: [id], onDelete: Cascade)

  @@index([vehicleVersionId])
  @@map("vehicle_documents")
}

model VehicleImage {
  id               Int              @id @default(autoincrement())
  vehicleVersionId Int
  type             VehicleImageType
  url              String
  createdAt        DateTime         @default(now())

  vehicleVersion   VehicleVersion   @relation(fields: [vehicleVersionId], references: [id], onDelete: Cascade)

  @@unique([vehicleVersionId, type])
  @@map("vehicle_images")
}

model TireManufacturer {
  id               Int              @id @default(autoincrement())
  name             String           @unique
  country          String
  website          String?
  notes            String?
  logoUrl          String?
  isActive         Boolean          @default(true)
  validationStatus ValidationStatus @default(NECESSITA_VALIDACAO)
  source           String?
  /// Nivel de confianca (0-100) da fonte que originou/atualizou este
  /// registro pela ultima vez. Null quando nao informado pela fonte.
  confidence       Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  families         TireFamily[]
  tires            Tire[]

  @@map("tire_manufacturers")
}

model TireFamily {
  id                 Int      @id @default(autoincrement())
  tireManufacturerId Int
  name               String
  createdAt          DateTime @default(now())

  tireManufacturer   TireManufacturer @relation(fields: [tireManufacturerId], references: [id])
  tires              Tire[]

  @@unique([tireManufacturerId, name])
  @@index([tireManufacturerId])
  @@map("tire_families")
}

enum TireCategory {
  PASSEIO
  SUV
  CAMINHONETE
  ESPORTIVO
  INVERNO
  COMERCIAL
}

enum TireSegment {
  POPULAR
  MEDIO
  PREMIUM
  LUXO
}

enum TireType {
  RADIAL
  DIAGONAL
}

model Tire {
  id                 Int              @id @default(autoincrement())
  tireManufacturerId Int
  tireFamilyId       Int?
  brand              String
  model              String
  size               String
  width              Int
  profile            Int
  rim                Int
  loadIndex          String
  speedIndex         String
  // Referencias normalizadas para os mesmos codigos de loadIndex/speedIndex
  // acima. Mantidas em paralelo aos campos de texto (usados pelos
  // formularios/CSV) para nao alterar a interface; preenchidas
  // automaticamente via find-or-create a cada gravacao.
  loadIndexId        Int?
  speedIndexId       Int?
  runFlat            Boolean          @default(false)
  xl                 Boolean          @default(false)
  seal               Boolean          @default(false)
  tubeless           Boolean          @default(true)
  // Codigo/selo PNCS (Programa Nacional de Conservacao de Combustivel/etiquetagem
  // Inmetro para pneus). Campo livre ate confirmarmos o formato oficial com o
  // usuario; permanece null ate ser validado por uma fonte oficial.
  pncs               String?
  type               TireType         @default(RADIAL)
  category           TireCategory
  segment            TireSegment?
  ean                String?          @unique
  description        String?
  imageUrl           String?
  isActive           Boolean          @default(true)
  validationStatus   ValidationStatus @default(NECESSITA_VALIDACAO)
  source             String?
  validatedBy        String?
  validatedAt        DateTime?
  confidence         Int?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  tireManufacturer   TireManufacturer   @relation(fields: [tireManufacturerId], references: [id])
  tireFamily         TireFamily?        @relation(fields: [tireFamilyId], references: [id])
  loadIndexRef       LoadIndex?         @relation(fields: [loadIndexId], references: [id])
  speedIndexRef      SpeedIndex?        @relation(fields: [speedIndexId], references: [id])
  homologationTires  HomologationTire[]
  technologies       TireTechnology[]
  images             TireImage[]

  @@unique([tireManufacturerId, model, size])
  @@index([tireManufacturerId])
  @@index([size])
  @@index([category])
  @@index([validationStatus])
  @@index([loadIndexId])
  @@index([speedIndexId])
  @@map("tires")
}

// Tabelas de referencia (normalizacao) para os codigos de indice de carga e
// velocidade. Nao sao pre-populadas nesta EPIC — cada codigo e
// registrado (find-or-create) na primeira vez que aparece em um pneu
// criado manualmente ou importado, junto com a origem que o trouxe.
model LoadIndex {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  maxLoadKg  Int?
  source     String?
  createdAt  DateTime @default(now())

  tires      Tire[]

  @@map("load_indexes")
}

model SpeedIndex {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  maxSpeedKmh  Int?
  source       String?
  createdAt    DateTime @default(now())

  tires        Tire[]

  @@map("speed_indexes")
}

// Galeria de fotos oficiais do pneu (complementar ao Tire.imageUrl, que
// permanece a foto de capa editavel manualmente). Permite multiplas fotos
// por fonte, todas rastreaveis por origem.
model TireImage {
  id        Int      @id @default(autoincrement())
  tireId    Int
  url       String
  source    String?
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())

  tire      Tire     @relation(fields: [tireId], references: [id], onDelete: Cascade)

  @@index([tireId])
  @@map("tire_images")
}

model Technology {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  tires       TireTechnology[]

  @@map("technologies")
}

model TireTechnology {
  tireId       Int
  technologyId Int
  createdAt    DateTime @default(now())

  tire       Tire       @relation(fields: [tireId], references: [id], onDelete: Cascade)
  technology Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([tireId, technologyId])
  @@index([technologyId])
  @@map("tire_technologies")
}

enum HomologationTireRole {
  ORIGINAL
  OPCIONAL
}

model Homologation {
  id               Int              @id @default(autoincrement())
  code             String
  vehicleVersionId Int
  /// Ano modelo (ano de referencia comercial do veiculo, ex.: "2024").
  year             Int
  /// Ano de fabricacao (ano civil em que a unidade foi efetivamente
  /// fabricada; pode divergir do ano modelo). Null ate ser confirmado.
  manufactureYear  Int?
  notes            String?
  validationStatus ValidationStatus @default(NECESSITA_VALIDACAO)
  source           String?
  validatedBy      String?
  validatedAt      DateTime?
  confidence       Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  vehicleVersion VehicleVersion         @relation(fields: [vehicleVersionId], references: [id])
  tires          HomologationTire[]
  documents      HomologationDocument[]

  @@unique([vehicleVersionId, code])
  @@index([vehicleVersionId])
  @@index([validationStatus])
  @@map("homologations")
}

model HomologationTire {
  id             Int                  @id @default(autoincrement())
  homologationId Int
  tireId         Int
  role           HomologationTireRole @default(ORIGINAL)
  createdAt      DateTime             @default(now())

  homologation Homologation @relation(fields: [homologationId], references: [id], onDelete: Cascade)
  tire         Tire         @relation(fields: [tireId], references: [id])

  @@unique([homologationId, tireId])
  @@index([tireId])
  @@map("homologation_tires")
}

model HomologationDocument {
  id             Int      @id @default(autoincrement())
  homologationId Int
  name           String
  url            String
  type           String?
  createdAt      DateTime @default(now())

  homologation   Homologation @relation(fields: [homologationId], references: [id], onDelete: Cascade)

  @@index([homologationId])
  @@map("homologation_documents")
}

enum UserRole {
  ADMIN
  USUARIO
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(USUARIO)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  importBatches ImportBatch[]
  auditLogs     AuditLog[]

  @@map("users")
}

model SearchLog {
  id           Int      @id @default(autoincrement())
  resumo       String
  veiculoBusca String?
  pneuBusca    String?
  resultCount  Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@map("search_logs")
}

enum ImportFileType {
  CSV
  XLSX
  ODS
  JSON
  XML
  PDF
  API
}

enum ImportEntity {
  MONTADORAS
  FABRICANTES_PNEUS
  VEICULOS
  PNEUS
  HOMOLOGACOES
}

enum ImportBatchStatus {
  PROCESSANDO
  CONCLUIDO
  CONCLUIDO_COM_ERROS
  FALHOU
  REVERTIDO
}

model ImportBatch {
  id             Int               @id @default(autoincrement())
  fileName       String
  fileType       ImportFileType
  entity         ImportEntity
  status         ImportBatchStatus @default(PROCESSANDO)
  userId         Int?
  totalRows      Int               @default(0)
  importedCount  Int               @default(0)
  updatedCount   Int               @default(0)
  duplicateCount Int               @default(0)
  errorCount     Int               @default(0)
  /// Versao/identificador da fonte oficial (ex.: "2026.1", ETag, hash do
  /// catalogo), quando o conector/arquivo informar. Null quando desconhecida.
  sourceVersion  String?
  /// Data em que a fonte informa ter publicado/coletado os dados
  /// (distinta de startedAt, que e quando este lote rodou). Null quando
  /// a fonte nao informa.
  collectedAt    DateTime?
  /// URL do endpoint/pagina de origem, quando existir (arquivos enviados
  /// manualmente nao tem URL).
  sourceUrl      String?
  /// Hash SHA-256 do conteudo importado (linhas brutas), para verificar
  /// integridade e detectar reimportacoes identicas de uma mesma fonte.
  importHash     String?
  startedAt      DateTime          @default(now())
  finishedAt     DateTime?
  durationMs     Int?
  rolledBackAt   DateTime?

  user           User?         @relation(fields: [userId], references: [id])
  errors         ImportError[]
  auditLogs      AuditLog[]

  @@index([status])
  @@index([entity])
  @@map("import_batches")
}

model ImportError {
  id            Int         @id @default(autoincrement())
  importBatchId Int
  rowNumber     Int?
  message       String
  rawData       String?
  createdAt     DateTime    @default(now())

  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@index([importBatchId])
  @@map("import_errors")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VALIDATE
  IMPORT
  ROLLBACK
}

model AuditLog {
  id            Int          @id @default(autoincrement())
  entity        String
  entityId      Int
  action        AuditAction
  userId        Int?
  importBatchId Int?
  changes       String?
  createdAt     DateTime     @default(now())

  user          User?        @relation(fields: [userId], references: [id])
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])

  @@index([entity, entityId])
  @@index([importBatchId])
  @@index([createdAt])
  @@map("audit_logs")
}
