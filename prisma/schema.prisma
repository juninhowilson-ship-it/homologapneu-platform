generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ValidationStatus {
  VALIDADO
  NECESSITA_VALIDACAO
  REJEITADO
}

enum FuelType {
  FLEX
  GASOLINA
  DIESEL
  ELETRICO
  HIBRIDO
}

enum VehicleCategory {
  HATCH
  SEDAN
  SUV
  PICAPE
  PERUA
  MINIVAN
  COUPE
}

enum VehicleSegment {
  POPULAR
  MEDIO
  PREMIUM
  LUXO
}

enum TransmissionType {
  MANUAL
  AUTOMATICA
  CVT
  AUTOMATIZADA
  DUPLA_EMBREAGEM
}

enum VehicleImageType {
  PRINCIPAL
  FRONTAL
  TRASEIRA
  LATERAL
}

enum DrivetrainType {
  DIANTEIRA
  TRASEIRA
  INTEGRAL
}

model Manufacturer {
  id                Int              @id @default(autoincrement())
  /// Marca comercial (ex.: "Chevrolet"). Nome principal, usado em toda a
  /// aplicacao (busca, homologacoes, etc.).
  name              String           @unique
  /// Montadora/razao social da entidade fabricante, quando distinta da
  /// marca comercial (ex.: "General Motors do Brasil Ltda."). Null quando
  /// marca e montadora coincidem ou ainda nao foi confirmada.
  legalName         String?
  automotiveGroupId Int?
  country           String?
  logoUrl           String?
  website           String?
  notes             String?
  isActive          Boolean          @default(true)
  /// Data de inicio da comercializacao oficial no Brasil.
  marketStartDate   DateTime?
  /// Data de encerramento da comercializacao no Brasil (null = ainda ativa
  /// ou desconhecida).
  marketEndDate     DateTime?
  validationStatus  ValidationStatus @default(NECESSITA_VALIDACAO)
  source            String?
  /// Nivel de confianca (0-100) da fonte que originou/atualizou este
  /// registro pela ultima vez. Null quando nao informado pela fonte.
  confidence        Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  automotiveGroup AutomotiveGroup? @relation(fields: [automotiveGroupId], references: [id])
  models          VehicleModel[]

  @@index([automotiveGroupId])
  @@map("manufacturers")
}

/// Grupo automotivo/holding que controla uma ou mais montadoras/marcas
/// (ex.: "Stellantis", "Volkswagen Group"). Tabela de referencia, vazia ate
/// ser populada via find-or-create pelo pipeline de importacao.
model AutomotiveGroup {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  manufacturers Manufacturer[]

  @@map("automotive_groups")
}

model VehicleModel {
  id             Int      @id @default(autoincrement())
  manufacturerId Int
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  manufacturer Manufacturer        @relation(fields: [manufacturerId], references: [id])
  generations  VehicleGeneration[]
  versions     VehicleVersion[]

  @@unique([manufacturerId, name])
  @@index([manufacturerId])
  @@map("vehicle_models")
}

model VehicleGeneration {
  id             Int      @id @default(autoincrement())
  vehicleModelId Int
  name           String
  yearStart      Int
  yearEnd        Int?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehicleModel VehicleModel     @relation(fields: [vehicleModelId], references: [id])
  versions     VehicleVersion[]

  @@unique([vehicleModelId, name])
  @@index([vehicleModelId])
  @@map("vehicle_generations")
}

model Engine {
  id        Int      @id @default(autoincrement())
  name      String
  fuel      FuelType
  power     String?
  /// Torque maximo (texto livre, ex.: "20,4 kgfm" ou "200 Nm") — formatos
  /// variam por fabricante/fonte, por isso mantido como texto como `power`.
  torque    String?
  turbo     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions VehicleVersion[]

  @@unique([name, fuel, power])
  @@map("engines")
}

/// Plataforma/arquitetura veicular (ex.: "MQB", "GM Gamma II"),
/// compartilhada por varias versoes/modelos. Tabela de referencia, vazia
/// ate ser populada via find-or-create pelo pipeline de importacao.
model Platform {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  versions VehicleVersion[]

  @@map("platforms")
}

model Transmission {
  id          Int              @id @default(autoincrement())
  type        TransmissionType
  gears       Int?
  description String?
  createdAt   DateTime         @default(now())

  versions VehicleVersion[]

  @@unique([type, gears, description])
  @@map("transmissions")
}

model VehicleVersion {
  id                   Int              @id @default(autoincrement())
  vehicleModelId       Int
  generationId         Int?
  engineId             Int
  transmissionId       Int?
  platformId           Int?
  name                 String
  /// Codigo interno do fabricante/fonte para esta versao (ex.: codigo de
  /// catalogo, codigo FIPE), quando existir.
  internalCode         String?
  yearStart            Int
  yearEnd              Int
  /// Ano de fabricacao (faixa), distinto do ano modelo (yearStart/yearEnd)
  /// quando a fonte informar essa diferenca. Null ate ser confirmado.
  manufactureYearStart Int?
  manufactureYearEnd   Int?
  category             VehicleCategory
  /// Categoria oficial de uso/classificacao do veiculo conforme orgao de
  /// transito (ex.: "Automovel", "Camioneta", "Utilitario") — distinta de
  /// `category` (carroceria). Texto livre ate normalizarmos com uma fonte
  /// oficial confirmada.
  regulatoryCategory   String?
  segment              VehicleSegment?
  drivetrain           DrivetrainType?
  doors                Int?
  /// Distancia entre eixos, em milimetros. Null ate ser confirmada por uma
  /// fonte real (ex.: ficha tecnica/infobox de fabricante ou enciclopedia).
  wheelbase            Int?
  /// Peso em ordem de marcha, em quilogramas. Null ate ser confirmado por
  /// uma fonte real.
  weight               Int?
  country              String?
  notes                String?
  isActive             Boolean          @default(true)
  validationStatus     ValidationStatus @default(NECESSITA_VALIDACAO)
  source               String?
  validatedBy          String?
  validatedAt          DateTime?
  confidence           Int?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  vehicleModel  VehicleModel       @relation(fields: [vehicleModelId], references: [id])
  generation    VehicleGeneration? @relation(fields: [generationId], references: [id])
  engine        Engine             @relation(fields: [engineId], references: [id])
  transmission  Transmission?      @relation(fields: [transmissionId], references: [id])
  platform      Platform?          @relation(fields: [platformId], references: [id])
  images        VehicleImage[]
  documents     VehicleDocument[]
  homologations Homologation[]

  @@unique([vehicleModelId, name, engineId])
  @@index([vehicleModelId])
  @@index([category])
  @@index([yearStart, yearEnd])
  @@index([validationStatus])
  @@index([platformId])
  @@map("vehicle_versions")
}

/// Documentos oficiais do veiculo (manual do proprietario, catalogo/ficha
/// tecnica), complementares as fotos em VehicleImage. type distingue o
/// tipo de documento (ex.: "MANUAL", "CATALOGO").
model VehicleDocument {
  id               Int      @id @default(autoincrement())
  vehicleVersionId Int
  name             String
  url              String
  type             String?
  createdAt        DateTime @default(now())

  vehicleVersion VehicleVersion @relation(fields: [vehicleVersionId], references: [id], onDelete: Cascade)

  @@index([vehicleVersionId])
  @@map("vehicle_documents")
}

model VehicleImage {
  id               Int              @id @default(autoincrement())
  vehicleVersionId Int
  type             VehicleImageType
  url              String
  createdAt        DateTime         @default(now())

  vehicleVersion VehicleVersion @relation(fields: [vehicleVersionId], references: [id], onDelete: Cascade)

  @@unique([vehicleVersionId, type])
  @@map("vehicle_images")
}

model TireManufacturer {
  id               Int              @id @default(autoincrement())
  name             String           @unique
  country          String
  website          String?
  notes            String?
  logoUrl          String?
  isActive         Boolean          @default(true)
  validationStatus ValidationStatus @default(NECESSITA_VALIDACAO)
  source           String?
  /// Nivel de confianca (0-100) da fonte que originou/atualizou este
  /// registro pela ultima vez. Null quando nao informado pela fonte.
  confidence       Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  families TireFamily[]
  tires    Tire[]

  @@map("tire_manufacturers")
}

model TireFamily {
  id                 Int      @id @default(autoincrement())
  tireManufacturerId Int
  name               String
  createdAt          DateTime @default(now())

  tireManufacturer TireManufacturer @relation(fields: [tireManufacturerId], references: [id])
  tires            Tire[]

  @@unique([tireManufacturerId, name])
  @@index([tireManufacturerId])
  @@map("tire_families")
}

enum TireCategory {
  PASSEIO
  SUV
  CAMINHONETE
  ESPORTIVO
  INVERNO
  COMERCIAL
}

enum TireSegment {
  POPULAR
  MEDIO
  PREMIUM
  LUXO
}

enum TireType {
  RADIAL
  DIAGONAL
}

model Tire {
  id                 Int              @id @default(autoincrement())
  tireManufacturerId Int
  tireFamilyId       Int?
  brand              String
  model              String
  size               String
  width              Int
  profile            Int
  rim                Int
  loadIndex          String
  speedIndex         String
  // Referencias normalizadas para os mesmos codigos de loadIndex/speedIndex
  // acima. Mantidas em paralelo aos campos de texto (usados pelos
  // formularios/CSV) para nao alterar a interface; preenchidas
  // automaticamente via find-or-create a cada gravacao.
  loadIndexId        Int?
  speedIndexId       Int?
  runFlat            Boolean          @default(false)
  xl                 Boolean          @default(false)
  seal               Boolean          @default(false)
  tubeless           Boolean          @default(true)
  // Codigo/selo PNCS (Programa Nacional de Conservacao de Combustivel/etiquetagem
  // Inmetro para pneus). Campo livre ate confirmarmos o formato oficial com o
  // usuario; permanece null ate ser validado por uma fonte oficial.
  pncs               String?
  type               TireType         @default(RADIAL)
  category           TireCategory
  segment            TireSegment?
  ean                String?          @unique
  description        String?
  imageUrl           String?
  isActive           Boolean          @default(true)
  validationStatus   ValidationStatus @default(NECESSITA_VALIDACAO)
  source             String?
  validatedBy        String?
  validatedAt        DateTime?
  confidence         Int?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  tireManufacturer  TireManufacturer   @relation(fields: [tireManufacturerId], references: [id])
  tireFamily        TireFamily?        @relation(fields: [tireFamilyId], references: [id])
  loadIndexRef      LoadIndex?         @relation(fields: [loadIndexId], references: [id])
  speedIndexRef     SpeedIndex?        @relation(fields: [speedIndexId], references: [id])
  homologationTires HomologationTire[]
  technologies      TireTechnology[]
  images            TireImage[]

  @@unique([tireManufacturerId, model, size])
  @@index([tireManufacturerId])
  @@index([size])
  @@index([category])
  @@index([validationStatus])
  @@index([loadIndexId])
  @@index([speedIndexId])
  @@map("tires")
}

// Tabelas de referencia (normalizacao) para os codigos de indice de carga e
// velocidade. Nao sao pre-populadas nesta EPIC — cada codigo e
// registrado (find-or-create) na primeira vez que aparece em um pneu
// criado manualmente ou importado, junto com a origem que o trouxe.
model LoadIndex {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  maxLoadKg Int?
  source    String?
  createdAt DateTime @default(now())

  tires Tire[]

  @@map("load_indexes")
}

model SpeedIndex {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  maxSpeedKmh Int?
  source      String?
  createdAt   DateTime @default(now())

  tires Tire[]

  @@map("speed_indexes")
}

// Galeria de fotos oficiais do pneu (complementar ao Tire.imageUrl, que
// permanece a foto de capa editavel manualmente). Permite multiplas fotos
// por fonte, todas rastreaveis por origem.
model TireImage {
  id        Int      @id @default(autoincrement())
  tireId    Int
  url       String
  source    String?
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())

  tire Tire @relation(fields: [tireId], references: [id], onDelete: Cascade)

  @@index([tireId])
  @@map("tire_images")
}

model Technology {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  tires TireTechnology[]

  @@map("technologies")
}

model TireTechnology {
  tireId       Int
  technologyId Int
  createdAt    DateTime @default(now())

  tire       Tire       @relation(fields: [tireId], references: [id], onDelete: Cascade)
  technology Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([tireId, technologyId])
  @@index([technologyId])
  @@map("tire_technologies")
}

enum HomologationTireRole {
  ORIGINAL
  OPCIONAL
}

model Homologation {
  id               Int              @id @default(autoincrement())
  code             String
  vehicleVersionId Int
  /// Ano modelo (ano de referencia comercial do veiculo, ex.: "2024").
  year             Int
  /// Ano de fabricacao (ano civil em que a unidade foi efetivamente
  /// fabricada; pode divergir do ano modelo). Null ate ser confirmado.
  manufactureYear  Int?
  notes            String?
  validationStatus ValidationStatus @default(NECESSITA_VALIDACAO)
  source           String?
  validatedBy      String?
  validatedAt      DateTime?
  confidence       Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  vehicleVersion VehicleVersion         @relation(fields: [vehicleVersionId], references: [id])
  tires          HomologationTire[]
  documents      HomologationDocument[]

  @@unique([vehicleVersionId, code])
  @@index([vehicleVersionId])
  @@index([validationStatus])
  @@map("homologations")
}

model HomologationTire {
  id             Int                  @id @default(autoincrement())
  homologationId Int
  tireId         Int
  role           HomologationTireRole @default(ORIGINAL)
  createdAt      DateTime             @default(now())

  homologation Homologation @relation(fields: [homologationId], references: [id], onDelete: Cascade)
  tire         Tire         @relation(fields: [tireId], references: [id])

  @@unique([homologationId, tireId])
  @@index([tireId])
  @@map("homologation_tires")
}

model HomologationDocument {
  id             Int      @id @default(autoincrement())
  homologationId Int
  name           String
  url            String
  type           String?
  createdAt      DateTime @default(now())

  homologation Homologation @relation(fields: [homologationId], references: [id], onDelete: Cascade)

  @@index([homologationId])
  @@map("homologation_documents")
}

enum EvidenceSourceType {
  MARKETPLACE
  DISTRIBUIDOR_OFICIAL
  FABRICANTE_PNEU
  MONTADORA
  MANUAL
  CATALOGO_OE
}

/// Ordem de forca crescente ate HOMOLOGACAO_VALIDADA; DIVERGENCIA e um
/// estado a parte (sobrepoe a pontuacao) quando duas aplicacoes distintas
/// e cada uma razoavelmente confirmada disputam o mesmo veiculo+versao+ano.
enum ApplicationStatus {
  EVIDENCIA_ISOLADA
  APLICACAO_COMERCIAL
  ALTA_CONFIANCA
  HOMOLOGACAO_VALIDADA
  DIVERGENCIA
}

/// Agrupa todas as evidencias que descrevem a MESMA aplicacao (mesmo pneu
/// + mesmo veiculo/versao/anos), por chave exata normalizada. O status e a
/// confianca aqui sao SEMPRE derivados das evidencias associadas — nunca
/// editados diretamente — conforme a regra de promocao definida pelo
/// usuario (ver services/homologationEvidence.ts).
model TireVehicleApplication {
  id                      Int               @id @default(autoincrement())
  tireManufacturerName    String
  tireModel               String
  tireSize                String
  vehicleManufacturerName String
  vehicleModel            String
  /// String vazia quando a versao nao e informada pela fonte — campos
  /// nulaveis nao funcionam de forma confiavel dentro de uma chave unica
  /// composta (NULL != NULL no Postgres), entao usamos "" como sentinela.
  vehicleVersion          String            @default("")
  /// 0 quando o ano nao e informado pela fonte (mesmo motivo do
  /// sentinela acima).
  yearStart               Int               @default(0)
  yearEnd                 Int               @default(0)
  status                  ApplicationStatus @default(EVIDENCIA_ISOLADA)
  /// Confianca agregada (nao e a confianca de uma fonte isolada): cresce
  /// quando fontes independentes confirmam a mesma aplicacao.
  confidence              Int               @default(0)
  evidenceCount           Int               @default(0)
  firstSeenAt             DateTime          @default(now())
  lastConfirmedAt         DateTime          @updatedAt

  evidences HomologationEvidence[]

  @@unique([tireManufacturerName, tireModel, tireSize, vehicleManufacturerName, vehicleModel, vehicleVersion, yearStart, yearEnd], name: "chaveAplicacao")
  @@index([status])
  @@map("tire_vehicle_applications")
}

/// Registro bruto e imutavel de UMA coleta de UMA fonte. Nunca e
/// atualizado nem apagado apos criado ("nunca perder nenhuma evidencia") —
/// e o pipeline de coleta por evidencias descrito na missao correspondente
/// (TireShop/Campneus/DPaschoal/PneuStore, fabricantes, montadoras,
/// manuais, catalogos OE). Nao representa uma homologacao por si so; o
/// status de homologacao vive em TireVehicleApplication.
model HomologationEvidence {
  id                      Int                @id @default(autoincrement())
  applicationId           Int
  tireManufacturerName    String
  tireModel               String
  tireSize                String
  vehicleManufacturerName String
  vehicleModel            String
  /// "" quando a fonte nao informa a versao (mesmo sentinela usado em
  /// TireVehicleApplication, para bater com a mesma chave normalizada).
  vehicleVersion          String             @default("")
  /// 0 quando a fonte nao informa o ano.
  yearStart               Int                @default(0)
  yearEnd                 Int                @default(0)
  sourceUrl               String
  sourceName              String
  sourceType              EvidenceSourceType
  collectedAt             DateTime
  /// Hash SHA-256 do conteudo bruto coletado (mesmo espirito de
  /// ImportBatch.importHash), para deteccao de recoleta identica.
  contentHash             String
  /// Confianca fixa atribuida ao TIPO da fonte no momento da coleta (ex.:
  /// marketplace=40, fabricante=70, montadora=90) — distinta da confianca
  /// agregada em TireVehicleApplication.
  sourceConfidence        Int
  createdAt               DateTime           @default(now())

  application TireVehicleApplication @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@index([sourceType])
  @@map("homologation_evidences")
}

enum UserRole {
  ADMIN
  USUARIO
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(USUARIO)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  importBatches      ImportBatch[]
  auditLogs          AuditLog[]
  documentUploads    DocumentUpload[]
  reviewedCandidates HomologationCandidate[]

  @@map("users")
}

enum DocumentFileType {
  PDF
  XLSX
  CSV
}

enum DocumentUploadStatus {
  PENDENTE
  PROCESSADO
  ERRO
}

/// Sistema de Curadoria Inteligente: upload de documento (PDF/Excel/CSV)
/// enviado por um usuário. O arquivo original fica guardado (fileContent)
/// para auditoria completa — nunca é publicado automaticamente; só serve
/// de base para gerar HomologationCandidate, que exige aprovação humana.
model DocumentUpload {
  id                 Int                  @id @default(autoincrement())
  fileName           String
  fileType           DocumentFileType
  /// Hash SHA-256 do arquivo original, para auditoria/deduplicação.
  fileHash           String
  fileSize           Int
  fileContent        Bytes
  /// Texto/linhas extraídos (via parseImportFile) antes da extração de
  /// candidatos — guardado para auditoria mesmo se a extração falhar.
  extractedText      String?
  /// Tipo de fonte que o usuário declara que este documento representa
  /// (marketplace/fabricante/montadora/manual/catálogo OE/distribuidor) —
  /// usado ao aprovar um candidato, para alimentar o Motor de Validação
  /// existente com o EvidenceSourceType correto.
  declaredSourceType EvidenceSourceType
  declaredSourceName String
  /// URL de onde o documento foi baixado, quando veio de um download
  /// automático (pipeline de expansão da Base Mestre) em vez de um
  /// upload manual pelo painel. Null para uploads manuais sem URL de
  /// origem informada.
  sourceUrl          String?
  /// Montadora/fabricante-alvo declarado no momento da busca/download
  /// (ex.: "Toyota") — estruturado à parte de declaredSourceName para
  /// permitir contagem/filtro por montadora sem parsear texto livre.
  manufacturerName   String?
  /// Data de publicação/revisão do próprio documento, quando a fonte
  /// informa (ex.: rodapé do manual, metadado do PDF). Null quando a
  /// fonte não declara — nunca inferida.
  publishedAt        DateTime?
  /// Confiabilidade (0-100) herdada do tipo de fonte no momento da
  /// captura (mesma escala de SOURCE_TYPE_POINTS em lib/constants/evidence.ts).
  reliability        Int                  @default(0)
  /// true quando o parser detectou um PDF escaneado (sem texto
  /// extraível) e o ambiente atual não tem OCR disponível — o documento
  /// fica registrado e vinculado, mas sem candidatos, até que OCR rode.
  ocrPending         Boolean              @default(false)
  status             DocumentUploadStatus @default(PENDENTE)
  errorMessage       String?
  uploadedById       Int?
  uploadedAt         DateTime             @default(now())

  uploadedBy User?                   @relation(fields: [uploadedById], references: [id])
  candidates HomologationCandidate[]

  @@index([status])
  @@index([fileHash])
  @@map("document_uploads")
}

enum CandidateStatus {
  PENDENTE_REVISAO
  APROVADA
  REJEITADA
  SOLICITAR_REVISAO
}

/// Homologação Candidata: extraída automaticamente de um DocumentUpload
/// por reconhecimento de padrões (nunca por invenção — só reconhece
/// marca/modelo já cadastrados no banco e padrões reais de medida/ano no
/// texto). NUNCA é publicada sozinha: só vira uma HomologationEvidence
/// real (via registrarEvidencia, o Motor de Validação já existente)
/// depois de um humano aprovar explicitamente.
model HomologationCandidate {
  id                      Int             @id @default(autoincrement())
  documentUploadId        Int
  tireManufacturerName    String?
  tireModel               String?
  tireSize                String?
  loadIndex               String?
  speedIndex              String?
  runFlat                 Boolean?
  xl                      Boolean?
  vehicleManufacturerName String?
  vehicleModel            String?
  vehicleVersion          String?
  yearStart               Int?
  yearEnd                 Int?
  /// Motor declarado no mesmo trecho da medida do pneu (ex.: "1.0 12V"),
  /// texto livre — só preenchido quando o próprio documento traz essa
  /// associação junto da especificação de pneu/roda.
  engine                  String?
  /// Especificação da roda (ex.: "6.5J x 16"), quando o documento
  /// declarar aro/roda separadamente da medida do pneu.
  wheelSize               String?
  /// Pressão recomendada do eixo dianteiro, texto livre (ex.: "2.1 bar",
  /// "30 psi") — mantém a unidade original da fonte, nunca convertida.
  frontTirePressure       String?
  /// Pressão recomendada do eixo traseiro, mesmas regras de
  /// frontTirePressure.
  rearTirePressure        String?
  /// Observações textuais literais do documento (ex.: ressalvas de
  /// carga/lotação) — nunca resumidas ou reescritas.
  observations            String?
  /// 0-100: quantos campos essenciais (pneu+veículo) foram reconhecidos
  /// com um match exato contra dados já cadastrados — nunca inferido.
  extractionConfidence    Int             @default(0)
  /// Trecho de texto de origem, para auditoria (o revisor confere contra
  /// a fonte original antes de aprovar).
  rawSnippet              String?
  status                  CandidateStatus @default(PENDENTE_REVISAO)
  reviewedById            Int?
  reviewedAt              DateTime?
  reviewNotes             String?
  /// Preenchido só quando aprovada — id da HomologationEvidence real
  /// criada pelo Motor de Validação existente (sem relação formal do
  /// Prisma para não alterar o modelo HomologationEvidence já existente).
  evidenceId              Int?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  documentUpload DocumentUpload @relation(fields: [documentUploadId], references: [id])
  reviewedBy     User?          @relation(fields: [reviewedById], references: [id])

  @@index([status])
  @@index([documentUploadId])
  @@map("homologation_candidates")
}

enum CrawlerDocumentCategory {
  MANUAL_PROPRIETARIO
  BOLETIM_TECNICO
  CATALOGO_PNEUS
  TABELA_HOMOLOGACAO
  PRESSAO_PNEUS
  RODA_ARO
  CATALOGO_TECNICO
  OUTRO
}

/// "HUB" = página índice que lista vários PDFs (ex.: legado.toyota.com.br/manuais),
/// exige um passo de extração de links antes do download. "DIRECT" = URL
/// que já aponta para um PDF/documento específico.
enum CrawlerSourceKind {
  HUB
  DIRECT
}

enum CrawlerSourceStatus {
  ATIVA
  BLOQUEADA
  PENDENTE
  ERRO
}

/// Catálogo permanente de fontes do HomologaPneu Intelligent Crawler — uma
/// linha por URL conhecida (página índice ou PDF direto) de um fabricante.
/// Distinto de DataSource (services/sourceManager.ts), que representa
/// MECANISMOS de importação (um conector por linha); aqui a granularidade é
/// por URL individual, populado por pesquisa real (nunca inventado) e
/// nunca duplicado (url é @unique).
model CrawlerSource {
  id               Int                     @id @default(autoincrement())
  manufacturerName String
  category         CrawlerDocumentCategory
  kind             CrawlerSourceKind
  url              String                  @unique
  /// null até a primeira visita verificar o robots.txt real do domínio.
  robotsAllowed    Boolean?
  status           CrawlerSourceStatus     @default(PENDENTE)
  lastVisitedAt    DateTime?
  /// Atualizado só quando o conteúdo (contentHash) muda em relação à
  /// visita anterior — distinto de lastVisitedAt, que muda a cada checagem.
  lastUpdatedAt    DateTime?
  /// Hash SHA-256 do conteúdo (HTML da página índice, ou bytes do PDF
  /// direto) na última visita — usado para detectar mudança real sem
  /// rebaixar nenhum documento já processado.
  contentHash      String?
  /// Achado real verificado (robots.txt, motivo de bloqueio, estrutura da
  /// página) — mesmo espírito do campo `finding` em evidenceSources.ts.
  notes            String?
  documentsFound   Int                     @default(0)
  /// ETag HTTP da última resposta (quando o servidor envia) — permite
  /// requisição condicional (If-None-Match) numa fonte DIRECT antes de
  /// baixar o corpo de novo.
  etag             String?
  /// Cabeçalho HTTP Last-Modified da última resposta, quando enviado
  /// pelo servidor (texto bruto, sem parsear) — distinto de
  /// `lastUpdatedAt`, que é calculado localmente a partir do contentHash.
  httpLastModified String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([manufacturerName])
  @@index([status])
  @@map("crawler_sources")
}

enum CrawlerRunTrigger {
  MANUAL
  SCHEDULED
}

enum CrawlerRunStatus {
  EXECUTANDO
  CONCLUIDO
  FALHOU
}

/// Histórico de execuções do crawler — nunca apagado, alimenta o
/// dashboard administrativo (documentos processados, falhas, tempo médio).
model CrawlerRun {
  id                  Int               @id @default(autoincrement())
  trigger             CrawlerRunTrigger
  status              CrawlerRunStatus  @default(EXECUTANDO)
  startedAt           DateTime          @default(now())
  finishedAt          DateTime?
  sourcesChecked      Int               @default(0)
  documentsFound      Int               @default(0)
  documentsDownloaded Int               @default(0)
  /// Documentos já conhecidos (mesmo hash) ou fontes bloqueadas — não
  /// contam como novo download nem como falha.
  documentsSkipped    Int               @default(0)
  candidatesCreated   Int               @default(0)
  errorCount          Int               @default(0)
  errorMessage        String?

  @@index([status])
  @@map("crawler_runs")
}

/// Linha única (id fixo = 1) com a preferência de frequência do scheduler.
/// O cron do Vercel (vercel.json) chama a rota diariamente no máximo; a
/// própria rota decide se executa de fato com base nesta configuração e em
/// CrawlerRun.startedAt do último run agendado concluído.
model CrawlerConfig {
  id            Int      @id
  frequency     String   @default("MANUAL")
  /// true = a execução em andamento deve parar assim que checar este
  /// flag entre uma fonte/documento e o próximo (cancelamento
  /// cooperativo — não existe um processo separado para matar). A rota
  /// que inicia uma execução nova sempre limpa este flag primeiro.
  stopRequested Boolean  @default(false)
  updatedAt     DateTime @updatedAt

  @@map("crawler_config")
}

enum CrawlerJobQueue {
  DOWNLOAD
  OCR
  PARSING
  CURADORIA
}

enum CrawlerJobStatus {
  PENDENTE
  EXECUTANDO
  CONCLUIDO
  ERRO
  AGUARDANDO_RETRY
}

/// Fila unificada de jobs do Intelligent Crawler — uma linha por unidade
/// de trabalho, filtrável por `queue` (DOWNLOAD/OCR/PARSING/CURADORIA).
/// Uma tabela só (em vez de 4 tabelas quase idênticas) porque o
/// mecanismo de retry/timeout/prioridade/log é o mesmo para as 4 —
/// mesmo espírito de ImportQueueItem (services/sourceManager.ts), que já
/// implementa "fila como dado + processarProximoDaFila()" para conectores;
/// aqui o formato do job é mais rico (tipo, prioridade, tentativas).
model CrawlerJob {
  id            Int              @id @default(autoincrement())
  queue         CrawlerJobQueue
  status        CrawlerJobStatus @default(PENDENTE)
  /// Maior = processado primeiro dentro da mesma fila.
  priority      Int              @default(0)
  /// Payload livre (JSON serializado) — formato depende de `queue` (ex.:
  /// DOWNLOAD carrega {url, sourceId}; CURADORIA carrega {documentUploadId}).
  payload       String
  attempts      Int              @default(0)
  maxAttempts   Int              @default(3)
  /// Calculado com backoff exponencial a cada falha — processarProximoJob
  /// só pega jobs com nextAttemptAt <= agora.
  nextAttemptAt DateTime         @default(now())
  timeoutMs     Int              @default(120000)
  startedAt     DateTime?
  finishedAt    DateTime?
  /// Log de execução acumulado (uma linha por tentativa) — auditoria
  /// simples; não há uma tabela de log separada para não sobre-projetar
  /// um sistema deste porte.
  log           String?
  error         String?
  createdAt     DateTime         @default(now())

  @@index([queue, status, priority])
  @@index([nextAttemptAt])
  @@map("crawler_jobs")
}

/// Alerta gerado quando um documento já conhecido (mesma sourceUrl) volta
/// com um SHA-256 diferente — ou seja, a fonte oficial publicou uma nova
/// versão. Histórico permanente (nunca apagado); comparar oldHash/newHash
/// com os DocumentUpload correspondentes dá o "antes/depois" completo.
model CrawlerAlert {
  id                       Int      @id @default(autoincrement())
  sourceUrl                String
  manufacturerName         String?
  previousDocumentUploadId Int?
  newDocumentUploadId      Int
  previousHash             String?
  newHash                  String
  message                  String
  acknowledged             Boolean  @default(false)
  createdAt                DateTime @default(now())

  @@index([acknowledged])
  @@index([sourceUrl])
  @@map("crawler_alerts")
}

model SearchLog {
  id           Int      @id @default(autoincrement())
  resumo       String
  veiculoBusca String?
  pneuBusca    String?
  resultCount  Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@map("search_logs")
}

enum ImportFileType {
  CSV
  XLSX
  ODS
  JSON
  XML
  PDF
  API
}

enum ImportEntity {
  MONTADORAS
  FABRICANTES_PNEUS
  VEICULOS
  PNEUS
  HOMOLOGACOES
}

enum ImportBatchStatus {
  PROCESSANDO
  CONCLUIDO
  CONCLUIDO_COM_ERROS
  FALHOU
  REVERTIDO
}

model ImportBatch {
  id             Int               @id @default(autoincrement())
  fileName       String
  fileType       ImportFileType
  entity         ImportEntity
  status         ImportBatchStatus @default(PROCESSANDO)
  userId         Int?
  totalRows      Int               @default(0)
  importedCount  Int               @default(0)
  updatedCount   Int               @default(0)
  duplicateCount Int               @default(0)
  errorCount     Int               @default(0)
  /// Versao/identificador da fonte oficial (ex.: "2026.1", ETag, hash do
  /// catalogo), quando o conector/arquivo informar. Null quando desconhecida.
  sourceVersion  String?
  /// Data em que a fonte informa ter publicado/coletado os dados
  /// (distinta de startedAt, que e quando este lote rodou). Null quando
  /// a fonte nao informa.
  collectedAt    DateTime?
  /// URL do endpoint/pagina de origem, quando existir (arquivos enviados
  /// manualmente nao tem URL).
  sourceUrl      String?
  /// Hash SHA-256 do conteudo importado (linhas brutas), para verificar
  /// integridade e detectar reimportacoes identicas de uma mesma fonte.
  importHash     String?
  startedAt      DateTime          @default(now())
  finishedAt     DateTime?
  durationMs     Int?
  rolledBackAt   DateTime?

  user      User?         @relation(fields: [userId], references: [id])
  errors    ImportError[]
  auditLogs AuditLog[]

  @@index([status])
  @@index([entity])
  @@map("import_batches")
}

model ImportError {
  id            Int      @id @default(autoincrement())
  importBatchId Int
  rowNumber     Int?
  message       String
  rawData       String?
  createdAt     DateTime @default(now())

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@index([importBatchId])
  @@map("import_errors")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VALIDATE
  IMPORT
  ROLLBACK
}

model AuditLog {
  id            Int         @id @default(autoincrement())
  entity        String
  entityId      Int
  action        AuditAction
  userId        Int?
  importBatchId Int?
  changes       String?
  createdAt     DateTime    @default(now())

  user        User?        @relation(fields: [userId], references: [id])
  importBatch ImportBatch? @relation(fields: [importBatchId], references: [id])

  @@index([entity, entityId])
  @@index([importBatchId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Catalogo formal de TODA fonte de dados conhecida (ativa ou bloqueada),
/// derivado automaticamente dos conectores reais ja implementados
/// (lib/importer/connectors/registry.ts + evidenceSources.ts) por
/// sincronizarCatalogoFontes() em services/sourceManager.ts — nunca
/// editado manualmente. category/type/status/mechanism sao String (nao
/// enum do Postgres) de proposito: adicionar uma fonte com uma categoria
/// nova nunca deve exigir uma migracao de schema.
model DataSource {
  id                          Int       @id @default(autoincrement())
  /// Identificador estavel do conector (ImportConnector.id ou
  /// EvidenceConnector.id) — ponte entre este catalogo e o codigo real.
  connectorId                 String    @unique
  /// "IMPORT" (ImportConnector, registry.ts) ou "EVIDENCE"
  /// (EvidenceConnector, evidenceSources.ts).
  mechanism                   String
  name                        String
  category                    String
  manufacturerName            String?
  type                        String
  baseUrl                     String?
  status                      String    @default("PENDENTE")
  /// Confiabilidade declarada (0-100) — dos tipos de fonte ja mapeados em
  /// SOURCE_TYPE_POINTS (lib/constants/evidence.ts) quando aplicavel.
  reliability                 Int       @default(0)
  lastSyncAt                  DateTime?
  updateFrequency             String?
  importedRecordsCount        Int       @default(0)
  confirmedHomologationsCount Int       @default(0)
  lastError                   String?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  queueItems ImportQueueItem[]

  @@index([status])
  @@index([category])
  @@map("data_sources")
}

/// Fila de processamento: cada item representa UMA execucao (passada ou
/// pendente) de uma fonte. Historico completo preservado (nunca apagado).
model ImportQueueItem {
  id         Int       @id @default(autoincrement())
  sourceId   Int
  status     String    @default("PENDENTE")
  createdAt  DateTime  @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  /// Resumo do resultado (JSON serializado) quando concluido com sucesso.
  result     String?
  error      String?

  source DataSource @relation(fields: [sourceId], references: [id])

  @@index([sourceId])
  @@index([status])
  @@map("import_queue_items")
}
